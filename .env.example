# .env.example

# Environment variables for SEO automation
SEO_API_KEY=your_api_key_here
SEO_API_SECRET=your_api_secret_here

# Google Search Console API
GSC_API_KEY=your_gsc_api_key_here
GSC_SITE_URL=https://yourwebsite.com

# Analytics tracking
ANALYTICS_TRACKING_ID=your_tracking_id_here
ANALYTICS_APP_NAME=your_app_name_here
